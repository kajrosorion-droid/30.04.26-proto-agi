def field_dynamics(field, scar, patterns, t):
    field[:,:,CH['vorticity']] *= Config.VORTICITY_DECAY
    field[:,:,CH['vorticity']] += np.gradient(field[:,:,CH['energy']])[0] * Config.GRADIENT_SENSITIVITY + np.gradient(field[:,:,CH['energy']])[1] * Config.GRADIENT_SENSITIVITY
    for x in range(Config.WORLD_SIZE):
        for y in range(Config.WORLD_SIZE):
            field[x, y, CH['vorticity']] += deterministic_noise(t, x, y, 0.01)
    for p in patterns:
        if not p.alive: continue
        for (x, y) in p.cells:
            scar[x, y] += Config.AGENT_SCAR_SENSE * p.epistemic_load
            field[x, y, CH['binding']] = min(1.0, field[x, y, CH['binding']] + Config.AGENT_BINDING_SENSE * p.unresolved_contradiction)
    scar *= Config.FIELD_DECAY
    field[:,:,CH['scar']] = np.clip(scar, 0, Config.SCAR_SATURATION)
    field[:,:,CH['energy']] += Config.HEARTBEAT_AMPLITUDE * np.sin(t * Config.HEARTBEAT_FREQ + field[:,:,CH['vorticity']]) + Config.SCAR_ENERGY_COUPLING * field[:,:,CH['scar']] + Config.VORTICITY_COUPLING * field[:,:,CH['vorticity']]
    field[:,:,CH['flux']] *= Config.GLOBAL_VISCOSITY
    for x in range(Config.WORLD_SIZE):
        for y in range(Config.WORLD_SIZE):
            field[x, y, CH['flux']] += Config.LOCAL_FATIGUE * deterministic_noise(t+1000, x, y, 0.01)
    return field, scar

def emergency_rescue(patterns, field, t):
    global next_pattern_id, layer_zero_manager
    alive = [p for p in patterns if p.alive]
    if len(alive) >= Config.MIN_POPULATION_FOR_SPAWN or t - layer_zero_manager.last_rescue_t < 30:
        return patterns
    normal_count = len([p for p in alive if p.role_type == "normal"])
    if normal_count >= Config.OVERPOPULATION_CAP:
        return patterns
    layer_zero_manager.last_rescue_t = t
    num_rescue = max(5, Config.MIN_PATTERNS_GUARANTEED - len(alive))
    donor_index = int(phi_hash(t, 0, 7777) * len(alive)) if alive else -1
    donor = alive[donor_index] if donor_index >= 0 else None
    new_patterns = []
    for i in range(num_rescue):
        if normal_count + i >= Config.OVERPOPULATION_CAP:
            break
        seed = int(phi_hash(t, i, 999) * Config.WORLD_SIZE * Config.WORLD_SIZE)
        x, y = seed % Config.WORLD_SIZE, (seed // Config.WORLD_SIZE) % Config.WORLD_SIZE
        field[x, y, CH['energy']] += 0.2
        field[x, y, CH['unknown']] += 0.1
        field[x, y, CH['owner']] = 0
        pid = next_pattern_id
        next_pattern_id += 1
        cells = {(x, y)}
        p = Pattern(pid, cells, parent=donor)
        if donor:
            p.belief = donor.belief + np.array([phi_hash(pid, i, 99)-0.5 for i in range(5)]) * 0.1
            p.model = donor.model.copy()
        p.update_properties(field)
        p.update_model(field)
        new_patterns.append(p)
    print(f"[t={t}] EMERGENCY RESCUE: spawned {num_rescue} patterns (donor={donor.id if donor else 'none'})")
    return patterns + new_patterns

def spawn_unknown_patterns(field, patterns, t, max_new=None):
    global next_pattern_id
    if max_new is None:
        max_new = Config.MAX_UNKNOWN_SPAWN_PER_STEP
    avg_unknown = safe_mean(field[:,:,CH['unknown']], 0)
    alive = [p for p in patterns if p.alive]
    normal_count = len([p for p in alive if p.role_type == "normal"])
    if avg_unknown < Config.UNKNOWN_SPAWN_THRESHOLD or normal_count >= Config.OVERPOPULATION_CAP:
        return patterns
    prob = Config.UNKNOWN_SPAWN_PROB * (avg_unknown / Config.UNKNOWN_SPAWN_THRESHOLD) * min(1.0, normal_count / Config.OVERPOPULATION_THRESHOLD)
    new_patterns = []
    new_count = 0
    done = False
    for x in range(Config.WORLD_SIZE):
        if done: break
        for y in range(Config.WORLD_SIZE):
            if new_count >= max_new or normal_count + new_count >= Config.OVERPOPULATION_CAP:
                done = True; break
            if field[x, y, CH['owner']] != 0: continue
            if field[x, y, CH['unknown']] > 0.5 and phi_hash(x, y, t) < prob:
                pid = next_pattern_id
                next_pattern_id += 1
                cells = {(x, y)}
                p = Pattern(pid, cells)
                p.update_properties(field)
                p.update_model(field)
                new_patterns.append(p)
                new_count += 1
                field[x, y, CH['unknown']] *= 0.8
    return patterns + new_patterns

def resolve_competitions_spatial(patterns, field, max_dist=None):
    if max_dist is None: max_dist = Config.COMPETITION_MAX_DISTANCE
    alive = [p for p in patterns if p.alive and p.cells]
    if len(alive) < 2: return
    cell_size = max(1, max_dist)
    spatial_map = {}
    for p in alive:
        cx = sum(c[0] for c in p.cells) // len(p.cells)
        cy = sum(c[1] for c in p.cells) // len(p.cells)
        key = (cx // cell_size, cy // cell_size)
        spatial_map.setdefault(key, []).append(p)
    checked_pairs = set()
    for (gx, gy), group in spatial_map.items():
        for dx in [-1, 0, 1]:
            for dy in [-1, 0, 1]:
                neighbor_key = (gx + dx, gy + dy)
                if neighbor_key not in spatial_map: continue
                others = spatial_map[neighbor_key]
                for p1 in group:
                    for p2 in others:
                        if p1.id >= p2.id: continue
                        pair = (p1.id, p2.id)
                        if pair in checked_pairs: continue
                        if not p1.cells & p2.cells: continue
                        checked_pairs.add(pair)
                        p1.compete(p2, field)

def process_spores(patterns, field):
    global next_pattern_id
    new_patterns = []
    alive = [p for p in patterns if p.alive]
    normal_count = len([p for p in alive if p.role_type == "normal"])
    for p in patterns:
        if not p.alive or p.pending_spore is None: continue
        spore = p.pending_spore
        if not (0 <= spore['x'] < Config.WORLD_SIZE and 0 <= spore['y'] < Config.WORLD_SIZE):
            p.pending_spore = None; continue
        if field[spore['x'], spore['y'], CH['owner']] != 0:
            continue
        if normal_count >= Config.OVERPOPULATION_CAP:
            continue
        pid = next_pattern_id
        next_pattern_id += 1
        cells = {(spore['x'], spore['y'])}
        child = Pattern(pid, cells, parent=p)
        child.scar_dream = spore['scar_dream']
        child.update_properties(field)
        child.update_model(field)
        new_patterns.append(child)
        field[spore['x'], spore['y'], CH['owner']] = child.id
        p.pending_spore = None
        normal_count += 1
    return patterns + new_patterns

