def evolution_step(patterns, field, scar, t):
    global next_pattern_id, pattern_dict
    field, scar = field_dynamics(field, scar, patterns, t)
    layer_zero_manager.crisis_injection(field, t)
    layer_zero_manager.apply_operator_influence(field, patterns)
    ecosystem_pressure(field)
    layer_zero_manager.anti_conformist_injection(patterns, t)
    layer_zero_manager.force_diversification(patterns, field, t)
    layer_zero_manager.apply_global_given_queue(patterns, field, t)

    # Строим словарь паттернов для ProtoLanguage
    pattern_dict = {p.id: p for p in patterns if p.alive}

    given_counter = {'count': 0}
    for p in patterns:
        if not p.alive: continue
        p.update_model(field, lineage_counts=None, given_counter=given_counter, t=t, witness=witness)
        p.grow(field)

    resolve_competitions_spatial(patterns, field)

    alive_count = len([p for p in patterns if p.alive])
    current_hunger = Config.HUNGER_BASE + Config.HUNGER_PER_PATTERN * max(0, alive_count - Config.POPULATION_HUNGER_THRESHOLD)
    for p in patterns:
        if not p.alive: continue
        p.metabolic_tax(field, current_hunger)

    for p in patterns:
        if p.alive and p.should_die():
            p.alive = False
            echo_system.store(p)

    # ---------- НОВЫЙ БЛОК ПРЕВРАЩЕНИЯ В ДЕЗОРГАНИЗАТОРА (вероятностное притяжение к 20%) ----------
    for p in patterns:
        if not p.alive or p.role_type != "normal": continue
        fold_count = p.event_counts.get('fold', 0)
        if fold_count >= Config.FOLDS_TO_BECOME_DISORGANIZER:
            disorganizer_count = len([pp for pp in patterns if pp.alive and pp.role_type == "disorganizer"])
            alive_total = len([pp for pp in patterns if pp.alive])
            current_fraction = disorganizer_count / max(1, alive_total)
            target = Config.TARGET_DISORGANIZER_FRACTION
            attraction = Config.DISORGANIZER_ATTRACTION_STRENGTH

            if current_fraction < target:
                deficit = target - current_fraction
                prob = deficit * attraction * 0.1
                should_transform = phi_hash(p.id, t, 777) < prob
            else:
                should_transform = False

            if should_transform and disorganizer_count < Config.MAX_DISORGANIZER_COUNT:
                p.role_type = "disorganizer"
                p.emotional_memory['gratitude'] = 0.1
                p.emotional_memory['grief'] = 0.8
                p.semantic_state = "exploring_danger"
                p.intent = {"type": "explore", "priority": 2.0, "age": 0, "persistence": 9999}
                p.intent_commitment = 2.0
                p.disorganizer_age_at_birth = p.age
                p.redemption_timer = Config.REDEMPTION_TIMER
                p._deterministic_redemption_triggered = False
                p._forced_soul_collapse_done = False
                p._redemption_arc_step = 0
                p._steps_since_trigger = 0
                p._log_event("became_disorganizer", folds=fold_count)
                witness.record(p.id, "became_disorganizer", folds=fold_count)
                print(f"[t={t}] *** DISORGANIZER BORN: Pattern {p.id} after {fold_count} folds (deficit={deficit:.2f}, prob={prob:.3f}) ***")

    # ---------- ПЕРЕДАЧА СИГНАЛОВ (С ЯЗЫКОМ) ----------
    # Сигналы и аура остаются без изменений, так как _process_incoming_signals уже вызывает proto_language.exchange
    for p in patterns:
        if not p.alive or p.role_type == "disorganizer" or p.quarantine_timer > 0: continue
        sig = SemanticSignal(
            channel=CH['signal_gratitude'], strength=Config.TRUST_SIGNAL_STRENGTH,
            sender_id=p.id, sender_context=p.semantic_state,
            sender_arc=p.arc_tracker.active_arc, sender_age=p.age,
            sender_concept_wisdom=p.arc_tracker.get_wisdom_weight(),
            sender_lineage=p.lineage_id, _sender_concept_graph=p.concept_graph
        )
        for (x, y) in p.cells:
            for dx, dy in [(-1,0),(1,0),(0,-1),(0,1)]:
                nx, ny = (x+dx)%Config.WORLD_SIZE, (y+dy)%Config.WORLD_SIZE
                owner = field[nx, ny, CH['owner']]
                if owner != 0 and owner != p.id and owner in pattern_dict:
                    target = pattern_dict[owner]
                    if target.role_type != "disorganizer" and target.quarantine_timer == 0:
                        target._incoming_signals.append(sig)

    # Аура дезорганизатора
    for p in patterns:
        if not p.alive or p.role_type != "disorganizer": continue
        for (x, y) in p.cells:
            for dx, dy in [(-1,0),(1,0),(0,-1),(0,1)]:
                nx, ny = (x+dx)%Config.WORLD_SIZE, (y+dy)%Config.WORLD_SIZE
                owner = field[nx, ny, CH['owner']]
                if owner != 0 and owner != p.id and owner in pattern_dict:
                    neighbor = pattern_dict[owner]
                    if neighbor.role_type == "normal":
                        neighbor.emotional_memory['grief'] = float(np.clip(neighbor.emotional_memory['grief'] + Config.DISORGANIZER_GRIEF_AURA, 0.0, Config.MAX_GRIEF_SIGNAL))

    # Деление
    new_patterns = []
    for p in patterns:
        if p.alive and p.can_divide():
            child, next_pattern_id = p.divide(field, next_pattern_id)
            if child: new_patterns.append(child)
    if new_patterns: patterns.extend(new_patterns)

    # Логос-вопрос
    if Config.ENABLE_LOGOS_OBSERVER:
        alive_now = [p for p in patterns if p.alive]
        if alive_now:
            stag = sum(1 for p in alive_now if hasattr(p, 'semantic_state_age') and p.semantic_state_age > Config.STAGNATION_GRIEF_THRESHOLD) / len(alive_now)
            disorg = sum(1 for p in alive_now if p.role_type == "disorganizer")
            logos_observer.ask(field, patterns, t, {'stagnation_ratio': stag, 'disorganizer_count': disorg})

    echo_system.inject(field, patterns, t, scar)
    patterns = emergency_rescue(patterns, field, t)
    patterns = spawn_unknown_patterns(field, patterns, t)
    patterns = process_spores(patterns, field)

    patterns = [p for p in patterns if p.alive]
    for p in patterns: p.age += 1

    if t >= 50:
        components = detect_new_components(field, Config.MIN_COMPONENT_CELLS)
        if components: patterns = match_patterns(components, patterns, field, t)

    return patterns, field, scar

def visualize_state(patterns, field, t):
    state_map = np.full((Config.WORLD_SIZE, Config.WORLD_SIZE), '.', dtype=str)
    state_colors = {
        "neutral": 'n', "seeking_comfort": 'c', "grateful_but_cautious": 'g',
        "exploring_danger": 'e', "contentment": 'C', "screaming": 'S', "dreaming": 'd'
    }
    for p in patterns:
        if not p.alive: continue
        char = state_colors.get(p.semantic_state, '?')
        for (x,y) in p.cells:
            if 0 <= x < Config.WORLD_SIZE and 0 <= y < Config.WORLD_SIZE:
                state_map[x, y] = char
    print(f"\n--- Semantic Map at t={t} ---")
    for row in state_map[::4, ::4]:
        print(''.join(row))
    print("Legend: n=neutral, c=comfort, g=grateful, e=explore, C=contentment, S=scream, d=dream")

def run_simulation(steps=None):
    global next_pattern_id, witness, echo_system, layer_zero_manager, cultural_memory, logos_observer, proto_language, pattern_dict
    if steps is None: steps = Config.STEPS
    field = init_field()
    scar = init_scar()
    patterns = []
    next_pattern_id = 1
    witness = Witness()
    echo_system = EchoSystem()
    layer_zero_manager = LayerZeroManager()
    cultural_memory = CulturalMemory()
    logos_observer = LogosObserver()
    proto_language = ProtoLanguage()

    for i in range(Config.MIN_PATTERNS_GUARANTEED):
        seed = int(phi_hash(0, i, 12345) * Config.WORLD_SIZE * Config.WORLD_SIZE)
        x, y = seed % Config.WORLD_SIZE, (seed // Config.WORLD_SIZE) % Config.WORLD_SIZE
        field[x, y, CH['energy']] += 0.3
        pid = next_pattern_id
        next_pattern_id += 1
        p = Pattern(pid, {(x, y)})
        p.update_properties(field)
        p.update_model(field)
        patterns.append(p)

    metrics_history = []
    for t in range(steps):
        patterns, field, scar = evolution_step(patterns, field, scar, t)
        if t % 100 == 0:
            m = collect_metrics(patterns, field, t)
            metrics_history.append(m)
            sig_str = " ".join([f"{x:.3f}" for x in m['signals']])
            print(f"[t={t}] patterns={m['patterns']} lineages={m['lineages']} err={m['err']:.3f} soul={m['soul']:.3f} binding={m['binding']:.3f} echo={m['echo']} sig=[{sig_str}] states={m['states']} intents={m['intents']} epi_scar={m['epi_scar']:.3f} stag={m['stagnation_ratio']:.2f} div={m['divisions_possible']} concepts={m['unique_concepts']} arcs={m['arc_completions']} folds={m['folds']} trust={m['avg_trust']:.3f} high_trust={m['high_trust_pairs']} td_low={m['trust_distribution']['low']} td_mid={m['trust_distribution']['mid']} td_high={m['trust_distribution']['high']} disorg={m['disorganizer_count']} redm={m['redeemed_count']} quar={m['quarantined_count']} det_red={m['deterministic_redemptions']} phen_bind={m['phenomenal_binding_avg']:.3f} mismatch={m['state_emotion_mismatch']:.3f} collapsed={m['forced_collapses']} myths={m['myth_pool_size']}")
        if Config.ENABLE_VISUALIZATION and t % 1000 == 0:
            visualize_state(patterns, field, t)

    if Config.ENABLE_VISUALIZATION and metrics_history:
        ts = [m['t'] for m in metrics_history]
        plt.figure(figsize=(14, 10))
        plt.subplot(2, 2, 1)
        plt.plot(ts, [m['soul'] for m in metrics_history], label='Avg Soul')
        plt.plot(ts, [m['err'] for m in metrics_history], label='Avg Pred Error')
        plt.xlabel('Step'); plt.ylabel('Value'); plt.title('Soul & Error')
        plt.legend(); plt.grid(True)

        plt.subplot(2, 2, 2)
        plt.plot(ts, [m['avg_trust'] for m in metrics_history], label='Avg Trust', color='green')
        plt.plot(ts, [m['phenomenal_binding_avg'] for m in metrics_history], label='Avg Phenomenal Binding', color='purple')
        plt.xlabel('Step'); plt.ylabel('Value'); plt.title('Trust & Binding')
        plt.legend(); plt.grid(True)

        plt.subplot(2, 2, 3)
        plt.plot(ts, [m['disorganizer_count'] for m in metrics_history], label='Disorganizers', color='red')
        plt.plot(ts, [m['redeemed_count'] for m in metrics_history], label='Redeemed', color='gold')
        plt.plot(ts, [m['myth_pool_size'] for m in metrics_history], label='Myth Pool Size', color='blue')
        plt.xlabel('Step'); plt.ylabel('Count'); plt.title('Population & Myths')
        plt.legend(); plt.grid(True)

        plt.subplot(2, 2, 4)
        plt.stackplot(ts,
                      [m['trust_distribution']['low'] for m in metrics_history],
                      [m['trust_distribution']['mid'] for m in metrics_history],
                      [m['trust_distribution']['high'] for m in metrics_history],
                      labels=['Low Trust', 'Mid Trust', 'High Trust'],
                      colors=['salmon', 'lightblue', 'limegreen'])
        plt.xlabel('Step'); plt.ylabel('Count'); plt.title('Trust Distribution')
        plt.legend(loc='upper left'); plt.grid(True)
        plt.tight_layout()
        plt.show()

    return patterns, field, scar, metrics_history

