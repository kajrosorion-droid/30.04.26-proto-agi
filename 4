            'stagnation_ratio': 0.0, 'divisions_possible': 0, 'arc_completions': 0, 'folds': 0,
            'avg_trust': 0.5, 'high_trust_pairs': 0,
            'trust_distribution': {'low': 0, 'mid': 0, 'high': 0},
            'disorganizer_count': 0, 'redeemed_count': 0, 'quarantined_count': 0,
