@dataclass
class SemanticSignal:
    channel: int; strength: float; sender_id: int; sender_context: str
    sender_arc: str | None; sender_age: int; sender_concept_wisdom: float
    sender_lineage: int; _sender_concept_graph: object

class TrustLedger:
    def __init__(self): self.entries: dict[int, float] = {}
    def update(self, sender_id: int, outcome: str):
        current = self.entries.get(sender_id, Config.TRUST_BASE)
        delta = {'helpful': Config.TRUST_DELTA_HELPFUL, 'neutral': Config.TRUST_DELTA_NEUTRAL, 'harmful': Config.TRUST_DELTA_HARMFUL}.get(outcome, 0.0)
        if outcome == 'helpful' and current > 0.6: delta *= 1.2
        self.entries[sender_id] = np.clip(current + delta, 0.0, 1.0)
    def get(self, sender_id: int) -> float: return self.entries.get(sender_id, Config.TRUST_BASE)

def interpret_signal(receiver, sig: SemanticSignal) -> float:
    weight = sig.strength
    if (sig.sender_context == "grateful_but_cautious" and receiver.semantic_state == "seeking_comfort"): weight *= 1.4
    if sig.sender_age > Config.WISDOM_AGE: weight *= 1.2
    if hasattr(receiver, 'concept_graph') and hasattr(sig, '_sender_concept_graph'):
        weight *= (1.0 + 0.4 * receiver.concept_graph.similarity(sig._sender_concept_graph))
    if hasattr(receiver, 'trust_ledger'):
        trust = receiver.trust_ledger.get(sig.sender_id)
        weight *= (0.6 + 0.8 * trust)
        if trust > 0.7 and sig.channel == CH['signal_gratitude']: weight *= Config.TRUST_GRATITUDE_AMPLIFY
    if sig.sender_lineage == receiver.lineage_id: weight *= 1.1
    return np.clip(weight, 0.0, 2.5)

