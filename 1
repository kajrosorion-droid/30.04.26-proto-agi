class Witness:
    def __init__(self, maxlen=100):
        self.log = deque(maxlen=maxlen)
    def record(self, pattern_id: int, event: str, **kwargs):
        if not Config.ENABLE_WITNESS: return
        self.log.append({"id": pattern_id, "event": event, **kwargs})
    def snapshot(self): return list(self.log)
    def summary(self): return Counter(ev["event"] for ev in self.log)

