        observed = np.array([avg_real[0], avg_unknown, avg_binding, avg_crisis_mem, local_gratitude, local_grief, len(self.cells)/100.0, self.energy])
        self.update_world_model(observed); self.generate_goals(field); self.update_intent(); self.form_concepts()
        self.apply_intent_actions(field); self.update_resonance(field); self.update_phase(field); self._heal_epistemic_scar()
