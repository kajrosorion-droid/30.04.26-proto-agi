    def update_properties(self, field):
        if not self.cells: self.alive = False; return
        self.energy = safe_mean([field[x,y,CH['energy']] for (x,y) in self.cells], 0.1)
        self.vorticity = safe_mean([field[x,y,CH['vorticity']] for (x,y) in self.cells], 0.0)

    def metabolic_tax(self, field, hunger_mult=1.0):
        if self.role_type == "disorganizer": hunger_mult *= 0.5
        if self.protection_level > 0: hunger_mult *= (1.0 - self.protection_level * 0.8)
        efficiency = 1.0/(1.0+self.pred_error)
        cost = self.genome['metabolic_cost']*len(self.cells)*(2.0 - efficiency)*hunger_mult
        if self.emotional_memory['grief'] > Config.EMOTIONAL_GRIEF_THRESHOLD: cost *= (1.0 + Config.GRIEF_METABOLIC_PENALTY*(self.emotional_memory['grief']-Config.EMOTIONAL_GRIEF_THRESHOLD))
        for (x,y) in self.cells:
            with np.errstate(divide='ignore', invalid='ignore'):
                take = min(max(field[x,y,CH['energy']], 0), cost/max(1, len(self.cells)))
            field[x,y,CH['energy']] -= take; cost -= take
        return cost

    def grow(self, field):
        if not self.alive or self.pred_error > Config.PRED_ERROR_THRESHOLD or self.in_dream: return
        intent_bias = 1.0; explore_bias_bonus = self.arc_tracker.get_explore_bias(); intent_bias += explore_bias_bonus
        if self.intent and self.intent["type"] == "explore": intent_bias = 1.5
        new_cells = set(); center_x, center_y = Config.WORLD_SIZE/2.0, Config.WORLD_SIZE/2.0; max_dist = np.sqrt(center_x**2 + center_y**2)
        for (x,y) in self.cells:
            for dx, dy in [(-1,0),(1,0),(0,-1),(0,1)]:
                nx, ny = (x+dx)%Config.WORLD_SIZE, (y+dy)%Config.WORLD_SIZE
                if field[nx, ny, CH['owner']] == 0:
                    strategy = self.genome['epistemic_strategy']; base_threshold = self.pred_error*(1.5 + 1.0*self.given_trigger)
                    if strategy > 0.66: base_threshold /= (1.0 + np.clip(field[nx,ny,CH['unknown']],0,0.8))
                    elif strategy >= 0.33: base_threshold *= (1.0 + max(0, np.clip(field[nx,ny,CH['unknown']],0,0.8)-self.unknown_prediction))
                    center_bonus = 0.0; dist_to_center = np.sqrt((nx-center_x)**2 + (ny-center_y)**2)
                    if self.unresolved_contradiction > 0.3: center_bonus = 0.60*(1.0 - dist_to_center/max_dist)*self.unresolved_contradiction
                    elif self.unresolved_contradiction < 0.15: center_bonus = -0.15*(1.0 - dist_to_center/max_dist)
                    if field[nx, ny, CH['surprise']] < base_threshold/intent_bias: new_cells.add((nx, ny))
        for cell in new_cells:
            dist = np.sqrt((cell[0]-center_x)**2 + (cell[1]-center_y)**2); threshold = 0.3
            if self.unresolved_contradiction > 0.3: threshold += 0.60*(1.0 - dist/max_dist)*self.unresolved_contradiction
            elif self.unresolved_contradiction < 0.15: threshold += 0.15*(dist/max_dist)
            growth_bonus = 0.3 * self.protection_level
            if phi_hash(cell[0], cell[1], self.id) < (threshold + growth_bonus): self.cells.add(cell); field[cell[0], cell[1], CH['owner']] = self.id

    def can_divide(self):
        adaptive_threshold = Config.DIVIDE_ERROR_THRESHOLD + self.soul_weight * (Config.DIVIDE_MAX_THRESHOLD - Config.DIVIDE_ERROR_THRESHOLD)
        if self.arc_tracker.completed_arcs: adaptive_threshold *= Config.ARC_DIVIDE_BONUS
        return (self.pred_error < adaptive_threshold and self.energy > Config.PATTERN_ENERGY_THRESHOLD and len(self.cells) >= Config.DIVIDE_MIN_SIZE * Config.DIVIDE_MIN_CELLS_MULT and self.alive and self.soul_weight > Config.DIVIDE_MIN_SOUL and self.age > Config.DIVIDE_MIN_AGE and self.fitness > Config.DIVIDE_MIN_FITNESS and (self.age - self.last_divide_age) > Config.DIVIDE_COOLDOWN and not self.in_dream)

    def divide(self, field, next_id):
        cells_list = list(self.cells); xs = [c[0] for c in cells_list]; median_x = np.median(xs)
        child1_cells = {c for c in cells_list if c[0] < median_x}; child2_cells = {c for c in cells_list if c[0] >= median_x}
        if len(child1_cells) < 3 or len(child2_cells) < 3: return None, next_id
        self.cells = child1_cells; child = Pattern(next_id, child2_cells, parent=self); child.role_type = "normal"
        if self.role_type == "disorganizer": child._log_event("born_from_disorganizer", parent_id=self.id)
        else: child._log_event("born_from_division", parent_id=self.id)
